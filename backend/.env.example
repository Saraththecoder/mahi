# Smart Agriculture AI Assistant - Backend Environment Variables Example

# MongoDB connection settings
# For production (Render), set this to your MongoDB Atlas connection string:
# MONGODB_URL=mongodb://localhost:27017
MONGODB_URL=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart_agriculture?retryWrites=true&w=majority

# Database name
DATABASE_NAME=smart_agriculture

# OpenWeather API Key (Sign up at https://openweathermap.org/ to get a free key)
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Frontend URL for CORS configuration (comma separated list)
# FRONTEND_URL=https://crop-ai-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
